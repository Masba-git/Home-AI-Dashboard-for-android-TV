# Application Settings
FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=your_secret_key_here_change_this
DEBUG=False

# Network Settings
HOST=0.0.0.0
PORT=5000

# CCTV Settings (optional - add your camera streams)
CCTV_STREAMS=camera1:rtsp://192.168.1.100:554/stream

# Optional: For free AI chatbot without OpenAI
# You can use local mode or HuggingFace free inference
USE_LOCAL_AI=True  # Set to True for rule-based chatbot